# ==============================================================================
# 🦞 MyClaw — Environment Configuration
# ==============================================================================
#
# 📌 HƯỚNG DẪN:
#   1. Copy file này:  cp .env.example .env
#   2. Điền giá trị thật vào .env
#   3. KHÔNG BAO GIỜ commit file .env lên Git!
#
# ==============================================================================

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🤖 LLM Provider — AI Model Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Provider: gemini | openai | anthropic | ollama
LLM_PROVIDER=gemini

# Model name (ví dụ: gemini-2.5-flash, gpt-4o, claude-sonnet-4-20250514)
LLM_MODEL=gemini-2.5-flash

# API Key cho LLM provider
LLM_API_KEY=your_llm_api_key_here

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 📨 Channel: Telegram (Active)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Chat ID — dùng cho cron job tự động gửi bản tin
# Lấy: nhắn tin cho bot → mở https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 📨 Channel: Slack (Coming Soon)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_SIGNING_SECRET=your_slack_signing_secret
# SLACK_CHANNEL_ID=C0123456789

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 📨 Channel: Microsoft Teams (Coming Soon)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# TEAMS_APP_ID=your_teams_app_id
# TEAMS_APP_PASSWORD=your_teams_app_password
# TEAMS_TENANT_ID=your_azure_tenant_id

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 📨 Channel: Zalo (Coming Soon)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ZALO_APP_ID=your_zalo_app_id
# ZALO_APP_SECRET=your_zalo_app_secret
# ZALO_OA_ACCESS_TOKEN=your_zalo_oa_access_token

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🔍 Search Engines — cho Web Search & Research Skills
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Tavily — AI search engine (khuyên dùng, free 1000 req/tháng)
# Đăng ký: https://app.tavily.com/sign-in
TAVILY_API_KEY=your_tavily_api_key_here

# Google Custom Search — tốt cho tiếng Việt (free 100 req/ngày)
# Setup: https://developers.google.com/custom-search/v1/overview
# GOOGLE_API_KEY=your_google_api_key
# GOOGLE_CX=your_google_search_engine_id

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 📰 Daily Payment Digest — Cấu hình bản tin
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Lịch chạy cron (format: phút giờ ngày tháng thứ)
# Mặc định: 8:00 AM mỗi ngày  |  Ví dụ: "0 7 * * 1-5" = 7h sáng T2-T6
DIGEST_CRON_SCHEDULE=0 8 * * *

# Thư mục lưu bản tin (mặc định: ~/digests)
DIGEST_OUTPUT_DIR=~/digests

# Delay giữa các search queries (giây) — tránh bị rate limit
# Giảm = nhanh hơn nhưng dễ bị block  |  Tăng = chậm nhưng ổn định
DIGEST_SEARCH_DELAY=0.8

# Phạm vi thời gian lấy tin:  d = 1 ngày  |  w = 1 tuần  |  m = 1 tháng
DIGEST_TIMELIMIT=w

# Số bài tối đa MỖI chuyên mục (6 mục × N bài)
DIGEST_MAX_RESULTS=5

# Độ dài tối đa snippet (ký tự)
DIGEST_SNIPPET_LENGTH=150

# Tin nhắn trigger gửi đến bot (dùng cho cron job)
DIGEST_TRIGGER_MESSAGE=Tạo bản tin thanh toán hôm nay

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ⚙️ OpenClaw Gateway Settings
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPENCLAW_SKILLS_DIR=~/.openclaw/skills
# OPENCLAW_LOG_LEVEL=info
